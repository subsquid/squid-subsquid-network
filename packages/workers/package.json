{
  "name": "@sqd/workers",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "rolldown -c && tsc -p tsconfig.model.json",
    "clean": "rm -rf lib",
    "codegen": "squid-typeorm-codegen",
    "db:migrate": "npx squid-typeorm-migration apply",
    "migration:generate": "npx squid-typeorm-migration generate",
    "migration:clean": "npx squid-typeorm-migration clean",
    "proc": "node -r dotenv/config lib/main.js",
    "api": "squid-graphql-server",
    "test": "vitest run"
  },
  "dependencies": {
    "@belopash/typeorm-store": "2.0.0-rc.7",
    "@oxc-project/runtime": "^0.125.0",
    "@sqd/shared": "workspace:*",
    "@subsquid/batch-processor": "0.2.0-portal-api.d5861e",
    "@subsquid/big-decimal": "^1.0.0",
    "@subsquid/evm-objects": "0.0.2-portal-api.d5861e",
    "@subsquid/evm-stream": "0.0.1-portal-api.d5861e",
    "@subsquid/graphql-server": "^4.12.0",
    "@subsquid/http-client": "^1.8.0",
    "@subsquid/logger": "^1.5.0",
    "@subsquid/typeorm-migration": "^1.3.1",
    "@subsquid/typeorm-store": "^1.9.0",
    "@subsquid/util-internal": "3.3.0-portal-api.fff2e3",
    "date-fns": "^3.6.0",
    "dotenv": "^16.6.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "1.2.0-rc.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@subsquid/typeorm-codegen": "2.2.0",
    "@types/node": "^20.19.39",
    "rolldown": "1.0.0-rc.15",
    "typescript": "~5.4.5",
    "vitest": "^2.1.9"
  }
}
